# Copy to .env and fill in. Never commit .env.
# All keys are FREE to obtain.

# AISStream.io - free WebSocket for global AIS vessel positions
# Register: https://aisstream.io/authenticate
AISSTREAM_API_KEY=

# FRED (St. Louis Fed) - free macro/commodity time series
# Register: https://fredaccount.stlouisfed.org/apikeys
FRED_API_KEY=

# NOAA NWS - free weather alerts (no key required, but set a User-Agent)
NOAA_USER_AGENT=SupplyChainPulse/0.1 (your-email@example.com)

# Anthropic - optional, for AI-generated executive summary
# Get a key: https://console.anthropic.com
ANTHROPIC_API_KEY=
ENABLE_CLAUDE_SUMMARY=false

# Cache config
CACHE_DB_PATH=./data/cache.sqlite
REFRESH_INTERVAL_MINUTES=15
